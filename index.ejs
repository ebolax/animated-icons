    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
        (function() {
            var currentCategory = 'all';
            var searchQuery = '';

            /**
             * Generic pagination for icon/font library grids. Respects currentCategory and searchQuery.
             * @returns {{ refresh: function() }} - refresh() reapplies category filter and resets to page 1
             */
            function createPagination(opts) {
                var perPage = opts.perPage != null ? opts.perPage : 80;
                var indexAttr = opts.indexAttr || 'data-index';
                var itemLabel = opts.itemLabel || 'icons';
                var itemSelector = '.icon-item[' + indexAttr + ']';

                var grid = document.getElementById(opts.gridId);
                var container = document.getElementById(opts.containerId);
                if (!grid || !container) return {
                    refresh: function() {}
                };

                var allItems = grid.querySelectorAll(itemSelector);
                var prevBtn = document.getElementById(opts.prevId);
                var nextBtn = document.getElementById(opts.nextId);
                var numbersEl = document.getElementById(opts.numbersId);
                var infoEl = document.getElementById(opts.infoId);
                var emptyStateEl = opts.emptyStateKey ? document.querySelector('[data-empty="' + opts.emptyStateKey + '"]') : null;
                if (!prevBtn || !nextBtn || !numbersEl || !infoEl) return {
                    refresh: function() {}
                };

                var filteredItems = [];
                var total = 0;
                var totalPages = 1;
                var currentPage = 1;

                function getFiltered() {
                    var cat = currentCategory;
                    var q = (searchQuery || '').trim().toLowerCase();
                    return Array.prototype.filter.call(allItems, function(item) {
                        if (cat !== 'all' && item.getAttribute('data-category') !== cat) return false;
                        if (q && (item.getAttribute('data-icon-name') || '').toLowerCase().indexOf(q) === -1) return false;
                        return true;
                    });
                }

                function goToPage(p) {
                    filteredItems = getFiltered();
                    total = filteredItems.length;
                    totalPages = Math.max(1, Math.ceil(total / perPage));
                    p = Math.max(1, Math.min(p, totalPages));
                    currentPage = p;

                    var start = (p - 1) * perPage;
                    var end = Math.min(start + perPage, total);

                    Array.prototype.forEach.call(allItems, function(item) {
                        var idx = filteredItems.indexOf(item);
                        if (idx === -1) {
                            item.classList.add('pagination-hidden');
                        } else if (idx >= start && idx < end) {
                            item.classList.remove('pagination-hidden');
                        } else {
                            item.classList.add('pagination-hidden');
                        }
                    });

                    if (total === 0) {
                        container.style.display = 'none';
                        if (emptyStateEl) emptyStateEl.style.display = 'block';
                        return;
                    }
                    container.style.display = '';
                    if (emptyStateEl) emptyStateEl.style.display = 'none';

                    prevBtn.disabled = p <= 1;
                    nextBtn.disabled = p >= totalPages;
                    renderPageNumbers();
                    infoEl.textContent = 'Showing ' + (start + 1) + '\u2013' + end + ' of ' + total + ' ' + itemLabel;
                }

                function renderPageNumbers() {
                    numbersEl.innerHTML = '';
                    // if (totalPages <= 1) return;

                    function addNum(n) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'pagination-num' + (n === currentPage ? ' active' : '');
                        btn.textContent = n;
                        btn.addEventListener('click', function() {
                            goToPage(n);
                        });
                        numbersEl.appendChild(btn);
                    }

                    function addEllipsis() {
                        var span = document.createElement('span');
                        span.className = 'pagination-ellipsis';
                        span.textContent = '\u2026';
                        numbersEl.appendChild(span);
                    }

                    addNum(1);
                    if (totalPages <= 5) {
                        if (totalPages > 1) addNum(2);
                        if (totalPages > 2) addNum(3);
                        if (totalPages > 3) addNum(4);
                        if (totalPages > 4) addNum(5);
                    } else if (currentPage > totalPages - 2) {
                        addEllipsis();
                        addNum(totalPages - 3);
                        addNum(totalPages - 2);
                        addNum(totalPages - 1);
                        if (totalPages > 1) addNum(totalPages);
                    } else {
                        if (currentPage > 3) addEllipsis();
                        addNum(currentPage > 2 ? currentPage - 1 : 2);
                        addNum(currentPage > 3 ? currentPage : 3);
                        addNum(currentPage > 3 ? currentPage + 1 : 4);
                        if (currentPage < totalPages - 2) addEllipsis();
                        if (totalPages > 1) addNum(totalPages);
                    }
                }

                prevBtn.addEventListener('click', function() {
                    goToPage(currentPage - 1);
                });
                nextBtn.addEventListener('click', function() {
                    goToPage(currentPage + 1);
                });

                function refresh() {
                    goToPage(1);
                }

                goToPage(1);
                return {
                    refresh: refresh
                };
            }

            function initAllPaginations() {
                var refreshFns = [];

                refreshFns.push(createPagination({
                    gridId: 'heroiconsGrid',
                    containerId: 'heroPagination',
                    prevId: 'heroPrev',
                    nextId: 'heroNext',
                    numbersId: 'heroPageNumbers',
                    infoId: 'heroPaginationInfo',
                    indexAttr: 'data-hero-index',
                    perPage: 80,
                    itemLabel: 'icons',
                    emptyStateKey: 'heroicons'
                }).refresh);

                refreshFns.push(createPagination({
                    gridId: 'iconoirGrid',
                    containerId: 'iconoirPagination',
                    prevId: 'iconoirPrev',
                    nextId: 'iconoirNext',
                    numbersId: 'iconoirPageNumbers',
                    infoId: 'iconoirPaginationInfo',
                    indexAttr: 'data-iconoir-index',
                    perPage: 80,
                    itemLabel: 'icons',
                    emptyStateKey: 'iconoir'
                }).refresh);

                refreshFns.push(createPagination({
                    gridId: 'lucideGrid',
                    containerId: 'lucidePagination',
                    prevId: 'lucidePrev',
                    nextId: 'lucideNext',
                    numbersId: 'lucidePageNumbers',
                    infoId: 'lucidePaginationInfo',
                    indexAttr: 'data-lucide-index',
                    perPage: 80,
                    itemLabel: 'icons',
                    emptyStateKey: 'lucide'
                }).refresh);

                var categoryFilters = document.getElementById('categoryFilters');
                if (categoryFilters) {
                    categoryFilters.addEventListener('click', function(e) {
                        var btn = e.target.closest('[data-category-filter]');
                        if (!btn) return;
                        var category = btn.getAttribute('data-category-filter');
                        if (category === currentCategory) return;

                        currentCategory = category;
                        categoryFilters.querySelectorAll('[data-category-filter]').forEach(function(el) {
                            el.classList.toggle('active', el.getAttribute('data-category-filter') === category);
                        });

                        refreshFns.forEach(function(fn) {
                            if (typeof fn === 'function') fn();
                        });
                    });
                }

                var iconSearch = document.getElementById('iconSearch');
                if (iconSearch) {
                    iconSearch.addEventListener('input', function() {
                        searchQuery = this.value;
                        refreshFns.forEach(function(fn) {
                            if (typeof fn === 'function') fn();
                        });
                    });
                }

                var currentColor = '#14b8a6';
                var colorsWrapper = document.getElementById('colors');
                if (colorsWrapper) {
                    colorsWrapper.addEventListener('click', function(e) {
                        var swatch = e.target.closest('.color-swatch');
                        if (!swatch) return;
                        var color = swatch.getAttribute('data-color');
                        if (!color) return;
                        currentColor = color;
                        colorsWrapper.querySelectorAll('.color-swatch').forEach(function(s) {
                            s.classList.toggle('active', s === swatch);
                        });
                        document.documentElement.style.setProperty('--aic-preview-primary', color);
                    });
                }

                var iconModalEl = document.getElementById('iconModal');
                var iconModalIcon = document.getElementById('iconModalIcon');
                var iconModalCode = document.getElementById('iconModalCode');
                var iconModalCopyBtn = document.getElementById('iconModalCopy');
                var iconModalCopied = document.getElementById('iconModalCopied');
                var iconModalLabel = document.getElementById('iconModalLabel');
                var iconModalColorApplyBtn = document.getElementById('iconModalColorApply');
                var iconModalColorRemoveBtn = document.getElementById('iconModalColorRemove');
                var iconModalAnimationSelect = document.getElementById('iconModalAnimationSelect');
                var iconModalClassName = '';
                if (iconModalEl && iconModalIcon && iconModalCode && iconModalCopyBtn && iconModalLabel && iconModalColorApplyBtn && iconModalAnimationSelect) {
                    var modal = new bootstrap.Modal(iconModalEl);

                    document.getElementById('iconTabContent').addEventListener('click', function(e) {
                        var item = e.target.closest('.icon-item');
                        if (!item) return;
                        var iEl = item.querySelector('i.aic');
                        if (!iEl) return;
                        e.preventDefault();

                        // reset the modal
                        iconModalAnimationSelect.value = 'default';
                        iconModalIcon.style = "";

                        iconModalClassName = iEl.className.trim();
                        iconModalLabel.textContent = iconModalClassName.replace('aic aic-', '');
                        iconModalIcon.className = iconModalClassName;
                        iconModalCode.textContent = '<i class="' + iconModalClassName + '"></i>';

                        if (iconModalCopied) iconModalCopied.classList.add('d-none');
                        modal.show();
                    });

                    iconModalColorApplyBtn.addEventListener('click', function() {
                        if (iconModalCode.textContent.includes("--aic-animation")) {
                            iconModalCode.textContent = '<i class="' + iconModalClassName + '" style="--aic-animation: ' + iconModalAnimationSelect.value + '; color: ' + currentColor + ';"></i>';
                        } else {
                            iconModalCode.textContent = '<i class="' + iconModalClassName + '" style="color: ' + currentColor + ';"></i>';
                        }
                    });

                    iconModalColorRemoveBtn.addEventListener('click', function() {
                        if (iconModalCode.textContent.includes("--aic-animation")) {
                            iconModalCode.textContent = '<i class="' + iconModalClassName + '" style="--aic-animation: ' + iconModalAnimationSelect.value + ';"></i>';
                        } else {
                            iconModalCode.textContent = '<i class="' + iconModalClassName + '"></i>';
                        }
                    });

                    iconModalAnimationSelect.addEventListener('change', function() {
                        if (this.value === 'default') {
                            iconModalIcon.style.removeProperty('--aic-animation');
                            if (iconModalCode.textContent.includes(currentColor)) {
                                iconModalCode.textContent = '<i class="' + iconModalClassName + '" style="color: ' + currentColor + ';"></i>';
                            } else {
                                iconModalCode.textContent = '<i class="' + iconModalClassName + '"></i>';
                            }
                        } else {
                            iconModalIcon.style.setProperty('--aic-animation', this.value);
                            if (iconModalCode.textContent.includes(currentColor)) {
                                iconModalCode.textContent = '<i class="' + iconModalClassName + '" style="--aic-animation: ' + this.value + '; color: ' + currentColor + ';"></i>';
                            } else {
                                iconModalCode.textContent = '<i class="' + iconModalClassName + '" style="--aic-animation: ' + this.value + ';"></i>';
                            }
                        }
                    });

                    iconModalCopyBtn.addEventListener('click', function() {
                        if (!iconModalCode.textContent) return;
                        navigator.clipboard.writeText(iconModalCode.textContent).then(function() {
                            if (iconModalCopied) {
                                iconModalCopied.classList.remove('d-none');
                                setTimeout(function() {
                                    iconModalCopied.classList.add('d-none');
                                }, 2000);
                            }
                        });
                    });
                }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initAllPaginations);
            } else {
                initAllPaginations();
            }
        })();
    </script>
</body>

</html>